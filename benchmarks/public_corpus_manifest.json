        "large-table", "string-data", "date-values", "unicode",
        "wide-headers", "minimal"
      ],
      "pptx": [
        "title-content", "multi-slide-5", "with-table", "with-bullets",
        "unicode", "mixed-layouts", "long-text", "minimal",
        "title-only", "content-heavy-8"
      ],
      "html": [
        "headings-paragraphs", "tables", "ordered-unordered-lists", "unicode",
        "nested-divs", "metadata-tags", "code-blocks", "links-images",
        "empty-body", "minimal"
      ],
      "csv": [
        "simple-tabular", "unicode", "empty-cells", "large-50rows",
        "single-column", "quoted-fields", "numeric-only", "mixed-types",
        "header-only", "minimal"
      ],
      "json": [
        "flat-object", "nested-object", "array-of-objects", "deeply-nested",
        "unicode", "null-values", "large-array", "mixed-types",
        "empty-object", "minimal"
      ],
      "xml": [
        "simple-elements", "nested-elements", "attributes", "unicode",
        "mixed-content", "deep-nesting", "namespaced", "cdata",
        "empty-elements", "minimal"
      ],
      "txt": [
        "paragraphs", "headings-sections", "unicode", "long-text",
        "lists", "minimal", "ascii-table", "code-like",
        "mixed-sections", "whitespace-heavy"
      ],
      "md": [
        "full-document", "tables", "code-blocks", "unicode",
        "nested-lists", "headings-h1-h6", "links-images", "blockquotes",
        "minimal", "long-text"
      ],
      "zip": [
        "single-text", "mixed-formats", "nested-dirs", "many-small-10",
