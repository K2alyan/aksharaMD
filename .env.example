# AksharaMD environment variables — copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── Required for URL fetch / benchmark eval ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
OPENAI_API_KEY=sk-proj-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
LLAMA_CLOUD_API_KEY=llx-REPLACE_ME

# ── MCP server (HTTP mode only) ───────────────────────────────────────────────
# Required when running --transport streamable-http. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AKSHARAMD_MCP_API_KEY=REPLACE_WITH_RANDOM_SECRET

# Restrict compile_document to files under this directory (strongly recommended).
# Must be an existing directory on the server.
AKSHARAMD_ALLOWED_ROOT=/data

# Max HTTP request body size in bytes (default: 1 MB)
# AKSHARAMD_MAX_BODY_BYTES=1048576

# Max file size for local files and URL downloads in bytes (default: 500 MB)
# AKSHARAMD_MAX_FILE_BYTES=524288000
